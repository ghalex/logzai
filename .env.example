# LogzAI Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# REQUIRED SETTINGS
# =============================================================================

# JWT Secret Key for token validation (REQUIRED)
# Generate with: openssl rand -base64 32
JWT_SECRET_KEY="your-secret-key-here"

# Fernet Encryption Key (REQUIRED)
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY="your-encryption-key-here"

# PostgreSQL Database URL (REQUIRED)
PG_DATABASE_URL="postgresql://logzai:logzai@logzai-db:5432/logzai"

# =============================================================================
# POSTGRESQL CONTAINER
# =============================================================================

POSTGRES_DB=logzai
POSTGRES_USER=logzai
POSTGRES_PASSWORD=logzai

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================

REDIS_URL=redis://logzai-redis:6379/0

# =============================================================================
# CELERY CONFIGURATION
# =============================================================================

CELERY_BROKER_URL=redis://logzai-redis:6379/0
CELERY_RESULT_BACKEND=redis://logzai-redis:6379/1
CELERY_LOG_LEVEL=info
CELERY_CONCURRENCY=2
CELERY_QUEUES=default,logs,ai
CELERY_WORKER_NAME=logzai-worker

# =============================================================================
# DATA DIRECTORY
# =============================================================================

# Root directory for all persistent data (logs, db, redis)
DATA_DIR=./data

# =============================================================================
# STORAGE CONFIGURATION
# =============================================================================

# Local storage path for log data (relative to /app inside container)
# Matches the bind mount target: ${DATA_DIR}/logs:/app/data
LOCAL_PATH=./data

# Use S3 for storage (True/False)
USE_S3=False

# =============================================================================
# S3 CONFIGURATION (only required if USE_S3=True)
# =============================================================================

S3_ENDPOINT=""
S3_BUCKET=""
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_REGION=""
S3_PATH=""

# =============================================================================
# LLM CONFIGURATION (OPTIONAL)
# =============================================================================

# Azure OpenAI
AZURE_LLM_API_KEY=""
AZURE_LLM_ENDPOINT=""
AZURE_LLM_API_VERSION=""
AZURE_LLM_DEPLOYMENT=""

# OpenAI
OPENAI_LLM_API_KEY=""
OPENAI_LLM_MODEL=""

# Anthropic
ANTHROPIC_LLM_API_KEY=""
ANTHROPIC_LLM_MODEL=""

# =============================================================================
# EMAIL CONFIGURATION (OPTIONAL)
# =============================================================================

MAILGUN_API_KEY=""
MAILGUN_DOMAIN=""
MAILGUN_FROM_EMAIL=""
